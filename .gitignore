# ============================================================
# Post-fate Odyssey - .gitignore
# What SHOULD be committed:
#   - Source code (src/, core_sim/src/, build.rs, Cargo.toml)
#   - Config files (webpack.config.js, tsconfig.json, package.json)
#   - Raw assets (public/assets/ PNGs, spritesheet atlas)
#   - Data files (data/*.csv)
#   - Documentation (*.md, GDD.md, Rule.md)
#   - HTML entry (public/index.html)
#   - Generated WASM bindings, bundles, lockfiles (all <100MB)
# ============================================================

# ============================================================
# RUST COMPILER OUTPUT (core_sim/target/)
# ~100MB+. Regenerated by: npm run build:wasm
# ============================================================
core_sim/target/

# Rust backup files
**/*.rs.bk

# ============================================================
# NODE_MODULES (web_client/node_modules/)
# ~103MB. Regenerated by: npm install
# ============================================================
web_client/node_modules/

# ============================================================
# INSTALLERS / LARGE BINARIES AT ROOT
# ============================================================
*.exe
*.msi
*.dmg
*.pkg

# ============================================================
# EDITOR & OS FILES
# ============================================================
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# TEMPORARY WORKSPACE FOLDERS (from Rule.md)
# ============================================================
/TempApp/
/TempFiles/
/bin/
